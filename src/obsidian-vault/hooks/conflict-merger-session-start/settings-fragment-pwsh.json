{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File .claude/hooks/conflict-merger-session-start/conflict-merger-session-start.ps1",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
