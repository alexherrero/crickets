#!/usr/bin/env bash
# pre-push — crickets PII guardrail.
#
# No automated installer copies this in yet — an operator installs it once
# manually: `cp src/pii/templates/hooks/pre-push .git/hooks/ && chmod +x
# .git/hooks/pre-push` (or `git config core.hooksPath` to a dir containing it).
# Runs `check-no-pii.sh` against the push range. Blocks the push on any finding.
#
# Receives on stdin lines of the form: <local_ref> <local_sha> <remote_ref> <remote_sha>
# (one per ref being pushed).

set -uo pipefail

# ── locate the crickets scanner ──────────────────────────────────────
# Try, in order:
#   1. $AGENT_TOOLKIT_PATH/scripts/check-no-pii.sh
#   2. Common dev-machine layouts (~/Antigravity/crickets, ~/dev/crickets)
#   3. Sibling-of-current-repo (../crickets/scripts/check-no-pii.sh)
SCRIPT="${AGENT_TOOLKIT_PATH:-}/scripts/check-no-pii.sh"
if [[ -z "${AGENT_TOOLKIT_PATH:-}" || ! -x "$SCRIPT" ]]; then
    for candidate in \
        "$HOME/Antigravity/crickets/scripts/check-no-pii.sh" \
        "$HOME/dev/crickets/scripts/check-no-pii.sh" \
        "../crickets/scripts/check-no-pii.sh"
    do
        if [[ -x "$candidate" ]]; then
            SCRIPT="$candidate"
            break
        fi
    done
fi

if [[ ! -x "$SCRIPT" ]]; then
    echo "pre-push: WARNING — crickets/scripts/check-no-pii.sh not found." >&2
    echo "  Searched: \$AGENT_TOOLKIT_PATH, ~/Antigravity/crickets, ~/dev/crickets, ../crickets" >&2
    echo "  PII guardrail SKIPPED (degraded gracefully). To enforce, set AGENT_TOOLKIT_PATH to a crickets checkout, or clone crickets alongside this repo." >&2
    exit 0
fi

# ── scan each ref being pushed ────────────────────────────────────────────
zero_sha="0000000000000000000000000000000000000000"
exit_code=0

while read -r local_ref local_sha remote_ref remote_sha; do
    # Skip deletions
    [[ "$local_sha" == "$zero_sha" ]] && continue

    if [[ "$remote_sha" == "$zero_sha" ]]; then
        # New branch — scan the whole working tree as a conservative default
        echo "pre-push: new branch — scanning entire working tree for PII..." >&2
        if ! bash "$SCRIPT" --all; then
            exit_code=1
        fi
    else
        # Existing branch — scan the push range
        range="${remote_sha}..${local_sha}"
        echo "pre-push: scanning $range for PII..." >&2
        if ! bash "$SCRIPT" --diff "$range"; then
            exit_code=1
        fi
    fi
done

if [[ $exit_code -ne 0 ]]; then
    echo "" >&2
    echo "pre-push: BLOCKED — PII findings in the push range." >&2
    echo "  Invoke the pii-scrubber skill for interactive remediation," >&2
    echo "  or fix manually and amend your commits." >&2
    echo "  See crickets CONTRIBUTING.md § PII guardrails for the override protocol." >&2
fi

exit $exit_code
