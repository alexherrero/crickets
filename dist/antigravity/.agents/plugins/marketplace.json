{
  "interface": {
    "displayName": "Crickets"
  },
  "name": "crickets",
  "plugins": [
    {
      "category": "Coding",
      "enhances": [
        {
          "capability": "review",
          "effect": "/review dispatches the adversarial reviewers (failing test / DEFECT: file:line / NO ISSUES FOUND)",
          "group": "developer-workflows"
        }
      ],
      "name": "code-review",
      "policy": {
        "authentication": "ON_INSTALL",
        "installation": "AVAILABLE"
      },
      "source": {
        "path": "./plugins/code-review",
        "source": "local"
      }
    },
    {
      "category": "Coding",
      "enhances": [
        {
          "group": "developer-workflows"
        }
      ],
      "name": "developer-safety",
      "policy": {
        "authentication": "ON_INSTALL",
        "installation": "AVAILABLE"
      },
      "source": {
        "path": "./plugins/developer-safety",
        "source": "local"
      }
    },
    {
      "capabilities": [
        "setup",
        "plan",
        "work",
        "review",
        "release",
        "bugfix",
        "documentation"
      ],
      "category": "Coding",
      "name": "developer-workflows",
      "policy": {
        "authentication": "ON_INSTALL",
        "installation": "AVAILABLE"
      },
      "source": {
        "path": "./plugins/developer-workflows",
        "source": "local"
      }
    },
    {
      "category": "Coding",
      "name": "github-ci",
      "policy": {
        "authentication": "ON_INSTALL",
        "installation": "AVAILABLE"
      },
      "requires": [
        "developer-workflows"
      ],
      "source": {
        "path": "./plugins/github-ci",
        "source": "local"
      }
    },
    {
      "category": "Coding",
      "name": "pii",
      "policy": {
        "authentication": "ON_INSTALL",
        "installation": "AVAILABLE"
      },
      "source": {
        "path": "./plugins/pii",
        "source": "local"
      }
    },
    {
      "category": "documentation",
      "enhances": [
        {
          "capability": "documentation",
          "effect": "phase commands dispatch the documenter to author/repair wiki pages at phase boundaries",
          "group": "developer-workflows"
        }
      ],
      "name": "wiki-maintenance",
      "policy": {
        "authentication": "ON_INSTALL",
        "installation": "AVAILABLE"
      },
      "source": {
        "path": "./plugins/wiki-maintenance",
        "source": "local"
      }
    }
  ]
}
