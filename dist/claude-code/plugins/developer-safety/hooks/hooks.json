{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/kill-switch/kill-switch.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/commit-on-stop/commit-on-stop.sh",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/steer/steer.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ]
  }
}
