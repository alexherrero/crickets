{
  "interface": {
    "displayName": "Crickets"
  },
  "name": "crickets",
  "plugins": [
    {
      "capabilities": [
        "adversarial-review"
      ],
      "category": "Coding",
      "enhances": [
        {
          "capability": "review",
          "effect": "/review dispatches the adversarial reviewers (failing test / DEFECT: file:line / NO ISSUES FOUND)",
          "group": "developer-workflows"
        }
      ],
      "name": "code-review",
      "policy": {
        "authentication": "ON_INSTALL",
        "installation": "AVAILABLE"
      },
      "source": {
        "path": "./dist/antigravity/plugins/code-review",
        "source": "local"
      }
    },
